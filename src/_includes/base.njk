<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta content="IE=edge" http-equiv="X-UA-Compatible">
  <meta content="width=device-width,initial-scale=1" name="viewport">
  <meta content="{{ description | default('Personal Website of Thomas Williams') }}" name="description">
  <meta name="google" content="notranslate" />
  <meta content="Thomas Williams" name="author">
  <meta name="msapplication-tap-highlight" content="no">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description | default('Personal Website of Thomas Williams') }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.twilliams.info{{ page.url }}">
  <meta property="og:image" content="https://www.twilliams.info/assets/images/NobleBubble2.png">
  <meta property="og:site_name" content="Tom Williams">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description | default('Personal Website of Thomas Williams') }}">
  <meta name="twitter:image" content="https://www.twilliams.info/assets/images/NobleBubble2.png">

  <link href="/assets/favicon.ico" rel="icon">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:900|Roboto+Mono:300,400,700">
  <link rel="stylesheet" href="/css/styles.css">
  {% if extraCss %}{{ extraCss | safe }}{% endif %}
</head>

<body class="{{ bodyClass }}">
<div id="site-border-left"></div>
<div id="site-border-right"></div>
<div id="site-border-top"></div>
<div id="site-border-bottom"></div>

<header>
  <nav class="navbar navbar-fixed-top {{ 'navbar-inverse' if bodyClass == 'minimal' else 'navbar-default' }}">
    <div class="container">
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse" aria-expanded="false" aria-label="Toggle navigation">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbar-collapse">
        <ul class="nav navbar-nav">
          <li><a href="/">Home</a></li>
          <li><a href="/research/">Research</a></li>
          <li><a href="/about/">About me</a></li>
          <li><a href="/cv/">CV</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
  </nav>
</header>

{{ content | safe }}

{% if not bodyClass == 'minimal' %}
<hr>
<footer class="footer-container text-center">
  <div class="container">
    <div class="row">
      <div class="col-xs-12">
        <a href="mailto:thomas_williams@brown.edu">
          <p>Tom Williams: Geochemist and Volcanologist</p>
        </a>
      </div>
    </div>
  </div>
</footer>
{% endif %}

<script src="/js/main.js"></script>
</body>

</html>
